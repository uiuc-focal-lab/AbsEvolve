+ // Construct to process a block of affine and quadratic operations together.
+ // This can be used to make the handling precise while using solvers
+ // that provide special handling for such kinds of basic blocks.
+ template <class BasicBlockLabel, class Number, class VariableName>
+ class quad_affine_block : public statement<BasicBlockLabel, Number, VariableName> {
+     using this_type = quad_affine_block<BasicBlockLabel, Number, VariableName>;
+ 
+ public:
+     using statement_t = statement<BasicBlockLabel, Number, VariableName>;
+     using binary_op_t = binary_op<BasicBlockLabel, Number, VariableName>;
+     using basic_block_t = typename statement_t::basic_block_t;
+     using variable_t = variable<Number, VariableName>;
+     using linear_expression_t = ikos::linear_expression<Number, VariableName>;
+ 
+     quad_affine_block(std::vector<binary_op_t> binary_ops,
+                       basic_block_t *parent,
+                       debug_info dbg_info = debug_info())
+         : statement_t(QUAD_AFFINE_BLOCK, parent, dbg_info),
+           m_binary_ops_list(binary_ops)
+     {
+         std::unordered_set<variable_t> lhs_vars_set_in_block;
+         int siz = m_binary_ops_list.size();
+ 
+         for (int i = 0; i < siz; i++) {
+            // Update the members
+            m_all_lhs.push_back(m_binary_ops_list[i].lhs());
+            m_all_ops.push_back(m_binary_ops_list[i].op());
+            m_all_left.push_back(m_binary_ops_list[i].left());
+            m_all_right.push_back(m_binary_ops_list[i].right());
+            
+
+            //
+            // Add a variable occuring the rhs expression to the uses of this block
+            // only if it is not defined inside this block.
+            //
+            
+            // Expression to the left of op
+            for(auto var: m_binary_ops_list[i].left().variables()) {
+                if (lhs_vars_set_in_block.find(var) == lhs_vars_set_in_block.end()) {
+                    this->m_live.add_use(var);
+                }
+            }
+
+            // Expression to the right of op
+            for(auto var: m_binary_ops_list[i].right().variables()) {
+                if (lhs_vars_set_in_block.find(var) == lhs_vars_set_in_block.end()) {
+                    this->m_live.add_use(var);
+                }
+            }
+
+             this->m_live.add_def(m_binary_ops_list[i].lhs());
+             lhs_vars_set_in_block.insert(m_binary_ops_list[i].lhs());
+         }
+     }
+ 
+     const std::vector<variable_t> all_lhs() const { return m_all_lhs; }
+
+     std::vector<binary_operation_t> all_ops() const { return m_all_ops; }
+   
+     const std::vector<linear_expression_t> all_left() const { return m_all_left; }
+   
+     const std::vector<linear_expression_t> all_right() const { return m_all_right; }
+ 
+     virtual void
+     accept(statement_visitor<BasicBlockLabel, Number, VariableName> *v) override {
+         v->visit(*this);
+     }
+ 
+     virtual statement_t *clone(basic_block_t *parent) const override {
+         return new this_type(this->m_binary_ops_list, parent, this->m_dbg_info);
+     }
+ 
+     virtual void write(crab_os &o) const override {
+         o << "[[";
+ 
+         int sz = m_binary_ops_list.size();
+         for (int i = 0; i < sz; i++) {
+            m_binary_ops_list[i].write(o);
+            o << "; ";
+         }
+ 
+         o << "]]";
+     }
+ 
+ private:
+     std::vector<binary_op_t> m_binary_ops_list;
+     std::vector<variable_t> m_all_lhs;
+     std::vector<binary_operation_t> m_all_ops;
+     std::vector<linear_expression_t> m_all_left;
+     std::vector<linear_expression_t> m_all_right;
+ };
