+void collateStatementsIntoBlocks(std::vector<statement_t*> statements) {
+    std::vector<bin_op_t> binop_statements;
+    for (auto stmt: statements) {
+        auto binOpStmt = dynamic_cast<bin_op_t*>(stmt);
+        binop_statements.push_back(*binOpStmt);
+    }
+
+    // Replace the first statement with the block.
+    replace(statements[0], new quad_affine_block_t(binop_statements, this));
+
+    for(int i=1; i<statements.size(); i++) {
+        remove(statements[i], false);
+    }
+}
