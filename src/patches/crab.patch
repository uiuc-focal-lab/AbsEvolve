+static std::unordered_map<std::string, std::string> to_unordered_map(const std::string &val) {
+    std::unordered_map<std::string, std::string> res;
+    std::stringstream ss(val);
+    
+    while (ss.good()) {
+        std::string pair;
+        getline(ss, pair, ',');  // Extract key-value pairs
+        
+        size_t pos = pair.find('->');
+        if (pos != std::string::npos) {  // Ensure valid key:value format
+            std::string key = pair.substr(0, pos-1);
+            std::string value = pair.substr(pos + 1);
+            res[key] = value;
+        }
+    }
+
+    return res;
