+void checkAndAddInQuadSet(variable_t currVar,
+                          lin_exp_t lhs,
+                          lin_exp_t rhs,
+                          std::unordered_set<variable_t>& quadVariablesSet)
+{
+    // Checks if any of the lhs or rhs vars set have some vars in the quadratic set
+    // and if yes, then currVar is also added in the set
+
+    for (auto var: lhs.variables()) {
+        if (quadVariablesSet.find(var) != quadVariablesSet.end()) {
+            quadVariablesSet.insert(currVar);
+            break;
+        }
+    }
+
+    for (auto var: rhs.variables()) {
+        if (quadVariablesSet.find(var) != quadVariablesSet.end()) {
+            quadVariablesSet.insert(currVar);
+        }
+    }
+}
+
+CollateStatus shouldCollateStmt(statement_t* stmt,
+                                AffinePrecisionLevel affinePrecLevel,
+                                QuadPrecisionLevel quadPrecLevel,
+                                std::unordered_set<variable_t>& quadVariablesSet,
+                                bool& isBlockQuadratic)
+{
+    if(auto binOpStmt = dynamic_cast<bin_op_t*>(stmt))
+    {
+        binary_operation_t binOp = binOpStmt->op();
+
+        if (binOp == BINOP_ADD || binOp == BINOP_SUB) {
+            lin_exp_t lhs = binOpStmt->left();
+            lin_exp_t rhs = binOpStmt->right();
+
+            if (!isBlockQuadratic && affinePrecLevel == AffinePrecisionLevel::DEFAULT) {
+                return NO_COLLATE;
+            }
+            else {
+                // Update the quadratic variables set: the present assigned variable is effectively
+                // quadratic if any of the current operands are quadratic.
+                checkAndAddInQuadSet(binOpStmt->lhs(), lhs, rhs, quadVariablesSet);
+                return THIS_BLOCK;
+            }
+        }
+        else if (binOp == BINOP_MUL) {
+            lin_exp_t lhs = binOpStmt->left();
+            lin_exp_t rhs = binOpStmt->right();
+
+            size_t lhs_vars_size = lhs.variables().size();
+            size_t rhs_vars_size = rhs.variables().size();
+
+            if (lhs_vars_size + rhs_vars_size <= 1) {
+                // Case when rhs is var*num
+                if (!isBlockQuadratic && affinePrecLevel == AffinePrecisionLevel::DEFAULT) {
+                    return NO_COLLATE;
+                }
+                else {
+                    // Update the quadratic variables set: the present assigned variable is effectively
+                    // quadratic if any of the current operands are quadratic.
+                    checkAndAddInQuadSet(binOpStmt->lhs(), lhs, rhs, quadVariablesSet);
+                    return THIS_BLOCK;
+                }
+            }
+            else {
+                // Case when rhs is var1 * var2
+
+                // Do not collate if the quad precision level is default.
+                if (quadPrecLevel == QuadPrecisionLevel::DEFAULT) {
+                    return NO_COLLATE;
+                }
+
+                //
+                // If mergeQuad is true, but if one of the multiplicants is already quadratic,
+                // then we should not collate this statement in the cuurent block as this
+                // will make the resultant non-quadratic.
+                //
+                // Eg:
+                // x = y * z
+                // a = x * v
+                //
+                // Resultant a is y * z * v
+                //
+                for (auto var: lhs.variables()) {
+                    if (quadVariablesSet.find(var) != quadVariablesSet.end()) {
+                        return NEXT_BLOCK;
+                    }
+                }
+
+                for (auto var: rhs.variables()) {
+                    if (quadVariablesSet.find(var) != quadVariablesSet.end()) {
+                        return NEXT_BLOCK;
+                    }
+                }
+
+                quadVariablesSet.insert(binOpStmt->lhs());
+                isBlockQuadratic = true;
+
+                return THIS_BLOCK;
+            }
+        }
+    }
+
+    return NO_COLLATE;
+}
