+find_path(GUROBI_INCLUDE_DIR NAMES gurobi_c.h PATHS ${GUROBI_PREFIX}/include NO_DEFAULT_PATH)
+
+find_library(GUROBI_CPP_LIBRARY NAMES gurobi_c++ PATHS ${GUROBI_PREFIX}/lib NO_DEFAULT_PATH)
