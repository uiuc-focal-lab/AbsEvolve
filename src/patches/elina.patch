diff --git a/precise_ops_handler/implementations/lin_constraints_solvers/CMakeLists.txt b/precise_ops_handler/implementations/lin_constraints_solvers/CMakeLists.txt
new file mode 100644
index 0000000000000000000000000000000000000000..c9752652929700a9acc63eb37cb458f60c09d6b7
