+                continue;  // Skip this combination
+            }
+
+            // Add the combinations to the vector
+            inner_set = {Utils::CoeffVar(1, vari), Utils::CoeffVar(-1, varj)};
+            combinations_to_compute.insert(inner_set);
+
+            inner_set = {Utils::CoeffVar(-1, vari), Utils::CoeffVar(1, varj)};
